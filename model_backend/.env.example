# Required
DATABASE_URL=postgresql+psycopg2://username:password@db-host:5432/dbname

# Optional if not using DATABASE_URL
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=dbname
# DB_USERNAME=username
# DB_PASSWORD=password

# Security: if empty, token check is disabled
SECRET_KEY=change-me

# CORS
CORS_ORIGINS=*

# Prediction storage
SAVE_PREDICTIONS=true

